      "id": "deductions-categories",
      "topic": "Deduction Categories",
      "category": "Federal Tax",
      "content": "Standard CTI deduction categories: travel (per IRS per-diem), equipment (Sec 179 / bonus depreciation), contractor vs. W-2 classification (DOL test + IRS 20-factor). Contractor mis-classification is a red flag — escalate any reclassification to Robert + legal.",
      "status": "draft",
      "lastUpdated": "2026-05-07"
    },
    {
      "id": "qet-thresholds",
      "topic": "Quarterly Estimated Tax Thresholds",
      "category": "Federal Tax",
      "content": "Safe harbor: 100% of prior-year liability (110% if prior-year AGI > $150K). Pay by Apr 15 / Jun 15 / Sep 15 / Jan 15. Underpayment penalty applies if shortfall exceeds $1,000 and no safe harbor met.",
      "status": "draft",
      "lastUpdated": "2026-05-07"
    }
